{
  "name": "appforge-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI Multi-Stage Application Generation Engine (hiring task). Converts natural language prompts into validated AppSpecs and includes AI providers, validation & repair engines, SSE, authentication, evaluation logging, and a premium UI/UX.",
  "author": "Rohit Agarwal",
  "license": "UNLICENSED",
  "keywords": [
    "ai",
    "appspec",
    "nextjs",
    "typescript",
    "zod",
    "sse",
    "openai",
    "anthropic",
    "gemini",
    "ai-engineering",
    "validation",
    "repair",
    "supabase",
    "sse-streaming",
    "ux"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "evaluate": "tsx scripts/evaluate.ts",
    "evaluate:watch": "tsx watch scripts/evaluate.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },

  "engines": {
    "node": ">=18.16.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/genai": "^2.6.0",
    "@hookform/resolvers": "^5.0.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.50.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.0.0",
    "groq-sdk": "^1.2.0",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.0.9",
    "next": "16.2.6",
    "openai": "^6.39.0",
    "pg": "^8.21.0",
    "pino": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.60.0",
    "recharts": "^3.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}